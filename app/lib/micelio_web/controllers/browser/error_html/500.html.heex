<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Something went wrong - Micelio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/assets/js/app.css" />
  </head>
  <body>
    <div class="error-page">
      <div class="error-page-code">500</div>
      <h1 class="error-page-title">Something went wrong</h1>
      <p class="error-page-message">
        An unexpected error occurred. Please try again later.
      </p>
      <div class="error-page-actions">
        <a href="/" class="error-page-link error-page-link-primary">
          Go home
        </a>
        <a
          href="javascript:history.back()"
          class="error-page-link error-page-link-secondary"
        >
          Go back
        </a>
      </div>
    </div>
  </body>
</html>
