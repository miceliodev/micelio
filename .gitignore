# The directory Mix will write compiled artifacts to.
/app/_build/

# If you run "mix test --cover", coverage assets end up here.
/app/cover/

# The directory Mix downloads your dependencies sources to.
/app/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/app/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/app/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/app/tmp/

# Local seed workspaces
/seeds/

# Ignore package tarball (built via "mix hex.build").
micelio-*.tar

# Ignore assets that are produced by build tools.
/app/priv/static/assets/

# Ignore digested assets cache.
/app/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/app/assets/node_modules/

/app/priv/lib/

.env
.direnv/
.devenv/
.mise.local.toml
.micelio-dev-instance

# Rust build artifacts
/mic/target/
/hif/target/

# Rust vendor/third-party
/mic/vendor/grpc/third_party/abseil-cpp/
/mic/vendor/grpc/third_party/boringssl-with-bazel/
/mic/vendor/grpc/third_party/cares/cares/
/mic/vendor/grpc/third_party/protobuf/
/mic/vendor/grpc/third_party/re2/
/mic/vendor/grpc/third_party/zlib/

# Local mic workspace state
/.mic/

# Logs
/logs/

# Kamal deployment secrets
/.kamal/secrets

# Android client artifacts
/mobile/android/.gradle/
/mobile/android/local.properties
/mobile/android/**/build/

# Claude Code
/.claude

# Agent Knowledge Base
/docs/akb
