    {
      "args": [
        {
          "description": "Project reference (e.g., acme/myapp)",
          "name": "org/project",
          "required": true
        }
      ],
      "category": "Workspace",
      "description": "Create a local workspace from a project",
      "examples": [
        {
          "command": "hif checkout acme/myapp",
          "description": "Checkout to ./myapp"
        },
        {
          "command": "hif checkout acme/myapp --path ./code",
          "description": "Checkout to ./code"
        }
      ],
      "name": "checkout",
      "notes": "After checkout, cd into the directory and start a session to begin working.",
      "options": [
        {
          "description": "Local directory path (defaults to project name)",
          "name": "--path, -p",
          "required": false
        }
      ],
      "usage": "hif checkout <ORG/PROJECT>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        }
      ],
      "category": "Workspace",
      "description": "Link current directory to an existing project",
      "examples": [
        {
          "command": "cd my-existing-code && hif link acme/myapp",
          "description": "Link existing directory to project"
        }
      ],
      "name": "link",
      "notes": "Use this when you have existing code you want to track. Unlike checkout, link doesn't download files.",
      "options": [],
      "usage": "hif link <ORG/PROJECT>"
    },
    {
      "args": [],
      "category": "Workspace",
      "description": "Show workspace status and local changes",
      "examples": [
        {
          "command": "hif status",
          "description": "Show all local changes"
        },
        {
          "command": "hif status --json",
          "description": "Output as JSON"
        }
      ],
      "name": "status",
      "notes": "Must be run from within a workspace (created by checkout or link).",
      "options": [],
      "output_format": {
        "A": "Added - new file",
        "D": "Deleted - removed file",
        "M": "Modified - changed file"
      },
      "usage": "hif status"
    },
    {
      "args": [],
      "category": "Workspace",
      "description": "Sync workspace with latest changes from forge",
      "examples": [
        {
          "command": "hif sync",
          "description": "Sync with interactive conflict resolution"
        },
        {
          "command": "hif sync --strategy ours",
          "description": "Keep local changes on conflict"
        },
        {
          "command": "hif sync --strategy theirs",
          "description": "Use remote changes on conflict"
        }
      ],
      "name": "sync",
      "options": [
        {
          "default": "interactive",
          "description": "Conflict resolution strategy: ours, theirs, or interactive (default)",
          "name": "--strategy, -s",
          "required": false
        }
      ],
      "usage": "hif sync"
    },
    {
      "category": "Sessions",
      "description": "Manage work sessions",
      "name": "session",
      "subcommands": [
        {
          "args": [
            {
              "description": "What you're trying to accomplish",
              "name": "goal",
              "required": true
            }
          ],
          "description": "Start a new session",
          "examples": [
            {
              "command": "hif session start \"Add user authentication\"",
              "description": "Start session (in workspace)"
            },
            {
              "command": "hif session start acme/myapp \"Fix login bug\"",
              "description": "Start session (outside workspace)"
            }
          ],
          "name": "start",
          "notes": "When run inside a workspace, the project is inferred automatically.",
          "options": [],
          "usage": "hif session start <GOAL>",
          "usage_outside_workspace": "hif session start <ORG/PROJECT> <GOAL>"
        },
        {
          "args": [],
          "description": "Show current session status",
          "examples": [
            {
              "command": "hif session status",
              "description": "Show active session details"
            }
          ],
          "name": "status",
          "options": [],
          "usage": "hif session status"
        },
        {
          "args": [
            {
              "description": "Note content",
              "name": "message",
              "required": true
            }
          ],
          "description": "Add a note to the current session",
          "examples": [
            {
              "command": "hif session note \"Decided to use JWT for auth\"",
              "description": "Add a decision note"
            },
            {
              "command": "hif session note \"Found the root cause\" --role agent",
              "description": "Add note from AI agent"
            }
          ],
          "name": "note",
          "notes": "Notes help capture context and decisions that will help future developers understand the code.",
          "options": [
            {
              "default": "human",
              "description": "Who is adding the note: human or agent",
              "name": "--role, -r",
              "required": false
            }
          ],
          "usage": "hif session note <MESSAGE>"
        },
        {
          "args": [],
          "description": "Land the session (push changes to forge)",
          "examples": [
            {
              "command": "hif session land",
              "description": "Push all changes to forge"
            }
          ],
          "name": "land",
          "notes": "If conflicts are detected, you'll be prompted to resolve them.",
          "options": [],
          "usage": "hif session land"
        },
        {
          "args": [],
          "description": "Abandon the session (discard all changes)",
          "examples": [
            {
              "command": "hif session abandon",
              "description": "Discard current session"
            }
          ],
          "name": "abandon",
          "options": [],
          "usage": "hif session abandon",
          "warning": "This will discard all uncommitted changes in the session."
        },
        {
          "args": [],
          "description": "Resolve conflicts interactively",
          "examples": [
            {
              "command": "hif session resolve",
              "description": "Interactively resolve conflicts"
            }
          ],
          "name": "resolve",
          "options": [
            {
              "default": "interactive",
              "description": "Resolution strategy",
              "name": "--strategy, -s",
              "required": false
            }
          ],
          "usage": "hif session resolve"
        }
      ]
    },
    {
      "args": [
        {
          "description": "What you accomplished",
          "name": "goal",
          "required": true
        }
      ],
      "category": "Sessions",
      "description": "Quick land: start session + land in one step",
      "examples": [
        {
          "command": "hif land \"Fix typo in README\"",
          "description": "Quick land (in workspace)"
        },
        {
          "command": "hif land acme/myapp \"Update dependencies\"",
          "description": "Quick land (outside workspace)"
        }
      ],
      "name": "land",
      "notes": "Use for small, self-explanatory changes. For larger work, use `hif session start` to add notes along the way.",
      "options": [],
      "usage": "hif land <GOAL>",
      "usage_outside_workspace": "hif land <ORG/PROJECT> <GOAL>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        },
        {
          "description": "File path",
          "name": "path",
          "required": true
        }
      ],
      "category": "Content",
      "description": "Show file contents from the forge (no checkout needed)",
      "examples": [
        {
          "command": "hif show acme/myapp README.md",
          "description": "Show current README"
        },
        {
          "command": "hif show acme/myapp src/main.rs --ref @10",
          "description": "Show file at position 10"
        }
      ],
      "name": "show",
      "notes": "Reads directly from the forge without creating a local workspace.",
      "options": [
        {
          "description": "Position reference (e.g., @10, @latest)",
          "name": "--ref, -r",
          "required": false
        }
      ],
      "usage": "hif show <ORG/PROJECT> <PATH>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        },
        {
          "description": "Directory path (defaults to root)",
          "name": "path",
          "required": false
        }
      ],
      "category": "Content",
      "description": "List directory contents from the forge",
      "examples": [
        {
          "command": "hif tree acme/myapp",
          "description": "List project root"
        },
        {
          "command": "hif tree acme/myapp src",
          "description": "List src/ directory"
        },
        {
          "command": "hif tree acme/myapp --ref @5",
          "description": "List at position 5"
        }
      ],
      "name": "tree",
      "options": [
        {
          "description": "Position reference",
          "name": "--ref, -r",
          "required": false
        }
      ],
      "usage": "hif tree <ORG/PROJECT> [PATH]"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        },
        {
          "description": "Search query or regex pattern",
          "name": "query",
          "required": true
        }
      ],
      "category": "Content",
      "description": "Search repository content",
      "examples": [
        {
          "command": "hif grep acme/myapp \"TODO\"",
          "description": "Search indexed content"
        },
        {
          "command": "hif grep acme/myapp \"panic!\" --path src/",
          "description": "Restrict to src/"
        },
        {
          "command": "hif grep acme/myapp \"fn\\\\s+main\" --regex",
          "description": "Regex search"
        },
        {
          "command": "hif grep acme/myapp \"TODO\" --local",
          "description": "Use local fallback on remote failure"
        }
      ],
      "name": "grep",
      "notes": "Uses forge search index by default and supports local fallback with --local.",
      "options": [
        {
          "description": "Position reference (e.g., @10, @latest)",
          "name": "--position",
          "required": false
        },
        {
          "description": "Restrict to path prefix",
          "name": "--path",
          "required": false
        },
        {
          "description": "Treat query as regex",
          "name": "--regex",
          "required": false
        },
        {
          "description": "Case-sensitive matching",
          "name": "--case-sensitive",
          "required": false
        },
        {
          "description": "Use local fallback when remote search fails",
          "name": "--local",
          "required": false
        },
        {
          "default": "20",
          "description": "Maximum number of matches",
          "name": "-n, --limit",
          "required": false
        }
      ],
      "usage": "hif grep <ORG/PROJECT> <QUERY>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        }
      ],
      "category": "History",
