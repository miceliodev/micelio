      "examples": [
        {
          "command": "hif log acme/myapp",
          "description": "Show recent sessions"
        },
        {
          "command": "hif log acme/myapp -n 50",
          "description": "Show last 50 sessions"
        },
        {
          "command": "hif log acme/myapp --path src/",
          "description": "Sessions that touched src/"
        }
      ],
      "name": "log",
      "options": [
        {
          "description": "Filter by file path",
          "name": "--path, -p",
          "required": false
        },
        {
          "default": "20",
          "description": "Maximum number of sessions to show",
          "name": "-n",
          "required": false
        }
      ],
      "usage": "hif log <ORG/PROJECT>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        },
        {
          "description": "File path",
          "name": "path",
          "required": true
        }
      ],
      "category": "History",
      "description": "Show who changed each line (session attribution)",
      "examples": [
        {
          "command": "hif blame acme/myapp src/main.rs",
          "description": "Show line-by-line attribution"
        }
      ],
      "name": "blame",
      "notes": "Shows which session last modified each line, along with the session goal.",
      "options": [],
      "usage": "hif blame <ORG/PROJECT> <PATH>"
    },
    {
      "args": [
        {
          "description": "Project reference",
          "name": "org/project",
          "required": true
        },
        {
          "description": "Starting position (e.g., @5)",
          "name": "from",
          "required": true
        },
        {
          "description": "Ending position (defaults to HEAD)",
          "name": "to",
          "required": false
        }
      ],
      "category": "History",
      "description": "Show changes between two positions",
      "examples": [
        {
          "command": "hif diff acme/myapp @5 @10",
          "description": "Changes from position 5 to 10"
        },
        {
          "command": "hif diff acme/myapp @5",
          "description": "Changes from position 5 to HEAD"
        }
      ],
      "name": "diff",
      "options": [],
      "usage": "hif diff <ORG/PROJECT> <FROM> [TO]"
    }
  ],
  "concepts": [
    {
      "description": "A unit of work with a goal, conversation, and file changes. Sessions replace Git commits but capture much more context.",
      "example": "hif session start \"Add user authentication\"",
      "name": "Session"
    },
    {
      "description": "A local directory linked to a project on the forge. Created with `hif checkout`.",
      "example": "hif checkout acme/myapp",
      "name": "Workspace"
    },
    {
      "description": "The Micelio server that stores all project data. Unlike Git, the forge is the source of truth.",
      "example": "https://micelio.dev",
      "name": "Forge"
    },
    {
      "description": "Pushing your session changes to the forge. Similar to Git push, but includes all session context.",
      "example": "hif session land",
      "name": "Landing"
    },
    {
      "description": "A point in project history, referenced as @N (e.g., @10). Similar to Git commit SHA but sequential.",
      "example": "hif show acme/myapp README.md --ref @5",
      "name": "Position"
    }
  ],
  "description": "The hif CLI - a forge-first version control system for the agent era",
  "environment_variables": [
    {
      "default": "~/.hif",
      "description": "Override config directory",
      "name": "HIF_HOME"
    },
    {
      "default": "",
      "description": "Disable colored output",
      "name": "NO_COLOR"
    }
  ],
  "error_codes": [
    {
      "code": "not_authenticated",
      "message": "Not logged in",
      "resolution": "Run `hif auth login`"
    },
    {
      "code": "token_expired",
      "message": "Authentication token expired",
      "resolution": "Run `hif auth login` again"
    },
    {
      "code": "not_in_workspace",
      "message": "Not in a workspace directory",
      "resolution": "Run `hif checkout <org/project>` first, or specify project explicitly"
    },
    {
      "code": "no_active_session",
      "message": "No active session",
      "resolution": "Run `hif session start \"<goal>\"` first"
    },
    {
      "code": "session_already_active",
      "message": "A session is already active",
      "resolution": "Run `hif session land` or `hif session abandon` first"
    },
    {
      "code": "invalid_project_ref",
      "message": "Invalid project reference format",
      "resolution": "Use format: org/project (e.g., 'acme/myapp')"
    },
    {
      "code": "conflicts_detected",
      "message": "Conflicts with upstream changes",
      "resolution": "Run `hif session resolve` or `hif sync`"
    }
  ],
  "global_options": [
    {
      "description": "Output in JSON format (for scripting and agents)",
      "name": "--json"
    },
    {
      "description": "Show additional details",
      "name": "--verbose, -v"
    },
    {
      "description": "Disable colored output",
      "name": "--no-color"
    },
    {
      "description": "Run as if started in <PATH> instead of current directory",
      "name": "--cwd, -C"
    },
    {
      "description": "Show help information",
      "name": "--help, -h"
    },
    {
      "description": "Show version information",
      "name": "--version, -V"
    }
  ],
  "installation": {
    "methods": [
      {
        "name": "Download binary",
        "platforms": [
          "macOS",
          "Linux",
          "Windows"
        ]
      },
      {
        "command": "cargo install hif",
        "name": "Build from source"
      }
    ],
    "requirements": [
      "Micelio account (sign up at micelio.dev)"
    ]
  },
  "introduction": {
    "key_differences_from_git": {
      "conflicts": {
        "git": "3-way merge",
        "hif": "Bloom filter detection + explicit resolution"
      },
      "history": {
        "git": "DAG of commits",
        "hif": "Append-only log of landing positions"
      },
      "storage": {
        "git": "Distributed (.git folder)",
        "hif": "Forge-first (server is source of truth)"
      },
      "unit_of_work": {
        "git": "Commit (snapshot)",
        "hif": "Session (goal + context + changes)"
      }
    },
    "what": "hif is an alternative to Git designed for the agent era. Instead of commits, you work in sessions that capture not just what changed, but why.",
    "why": [
      "Sessions capture goals, conversations, and decisions alongside code changes",
      "Forge-first design means the server is the source of truth",
      "Built for AI agents to understand and contribute to codebases",
      "Simpler mental model: no staging area, no rebasing, no merge commits"
    ]
  },
  "name": "hif",
  "quick_start": {
    "quick_land": {
      "command": "hif land \"Fix typo in README\"",
      "description": "For small changes, combine session start and land:"
    },
    "steps": [
      {
        "command": "hif auth login",
        "description": "Opens browser for OAuth authentication",
        "step": 1,
        "title": "Authenticate"
      },
      {
        "command": "hif checkout acme/myapp",
        "description": "Downloads project and creates local workspace",
        "step": 2,
        "title": "Create workspace"
      },
      {
        "command": "hif session start \"Add feature\"",
        "description": "Begin tracking your work with a goal",
        "step": 3,
        "title": "Start session"
      },
      {
        "command": "# Edit files normally",
        "description": "Use your favorite editor, no staging needed",
        "step": 4,
        "title": "Make changes"
      },
      {
        "command": "hif session land",
        "description": "Push your session to the forge",
        "step": 5,
        "title": "Land changes"
      }
    ],
    "title": "Quick Start"
  },
  "see_also": {
    "api": "https://micelio.dev/docs/api",
    "docs": "https://micelio.dev/docs",
    "website": "https://micelio.dev"
  },
  "tagline": "Version control designed for AI-assisted development",
  "version": "0.1.0"
}
